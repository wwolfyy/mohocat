 rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to the points collection
    match /points/{x} {
      allow read: if true;  // Allows anyone to read
      allow write: if false;  // No one can write
    }

    // Allow read access to the cats collection
    match /cats/{x} {
      allow read: if true; 
      allow write: if false;  
    }

    // Allow read access to the cats collection
    match /about_content/{x} {
      allow read: if true; 
      allow write: if false;  
    }

    // Allow read access to the cats collection
    match /cat_images/{x} {
      allow read: if true; 
      allow write: if false;  
    }
    
    // Allow read access to the cats collection
    match /cat_videos/{x} {
      allow read: if true; 
      allow write: if false;  
    }    

    // Allow read access to the cats collection
    match /posts_announcements/{x} {
      allow read: if true; 
      allow write: if false;  
    }

    // Allow read access to the feeding_spots collection
    // match /feeding_spots/{x} {
    //   allow read: if true;  
    //   allow write: if false;  
    // }

    // Allow read and write access to the posts_feeding collection for authenticated users
    match /posts_feeding/{document} {
      allow read, write: if request.auth != null;  
    }

    // Allow read and write access to the posts_feeding collection for authenticated users
    match /posts_butler/{document} {
      allow read, write: if request.auth != null; 
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
      }
    
    // rules for dev/test (allow everything)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}