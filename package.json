{
  "name": "mcathcat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/migration/export_all_to_cloud_storage.js && node scripts/maintenance/fetch-static-assets.js && next build",
    "start": "next start",
    "lint": "next lint",
    "script:add-updated-field": "node scripts/migration/add_updated_field.js",
    "script:add-updated-field-admin": "node scripts/migration/add_updated_field_admin.js",
    "script:remove-thumbnailUrl": "node scripts/remove_thumbnailUrl_field.js",
    "update:static-data": "node scripts/migration/update_all_static_data.js",
    "update:cats": "node scripts/migration/export_cats_to_static.js",
    "update:points": "node scripts/migration/export_points_to_static.js",
    "update:feeding-spots": "node scripts/migration/export_feeding_spots_to_static.js",
    "docker:build": "docker build -t mcathcat .",
    "docker:run": "docker run -p 8080:8080 --env-file .env.local mcathcat",
    "docker:build-and-run": "npm run docker:build && npm run docker:run",
    "cloud-run:deploy": "gcloud run deploy mcathcat --source . --platform managed --region asia-northeast3 --allow-unauthenticated",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@heroicons/react": "^2.2.0",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "axios": "^1.9.0",
    "busboy": "^1.6.0",
    "clsx": "^2.1.0",
    "dotenv": "^16.5.0",
    "firebase": "^10.8.0",
    "firebase-admin": "^13.4.0",
    "googleapis": "^149.0.0",
    "next": "^14.2.29",
    "open": "^10.1.2",
    "ra-data-fakerest": "^5.8.3",
    "ra-data-firebase-client": "^3.0.0",
    "ra-ui-materialui": "^5.8.3",
    "react": "^18",
    "react-admin": "^5.8.3",
    "react-dom": "^18",
    "react-hook-form": "^7.58.0",
    "react-icons": "^5.5.0",
    "swr": "^2.3.7",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
